[
  {
    "name": "Buy eSIM — opens country selection from menu",
    "steps": [
      {
        "send": { "callback": "product:select" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "Where are you traveling? Pick a country to see available eSIM plans." }
          }
        ]
      }
    ]
  },
  {
    "name": "Buy eSIM — /buy command opens country selection",
    "steps": [
      {
        "send": { "text": "/buy" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Where are you traveling? Pick a country to see available eSIM plans." }
          }
        ]
      }
    ]
  },
  {
    "name": "Buy eSIM — selecting a country shows plans",
    "steps": [
      {
        "send": { "callback": "purchase:country_select" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "purchase:country:JP" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "🇯🇵 Japan — available plans:\n\nChoose a plan below:" }
          }
        ]
      }
    ]
  },
  {
    "name": "Buy eSIM — selecting a plan shows details and activation",
