[
  {
    "name": "Travel Assistant — opens topic menu",
    "steps": [
      {
        "send": { "callback": "ai:chat" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "What can I help you with?\n\nPick a topic below, or just type your travel question." }
          }
        ]
      }
    ]
  },
  {
    "name": "Travel Assistant — selecting a topic shows info",
    "steps": [
      {
        "send": { "callback": "ai:chat" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "ai:topic:visa" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  },
  {
    "name": "Travel Assistant — typing a keyword matches a topic",
    "steps": [
      {
        "send": { "callback": "ai:chat" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "tell me about visas" },
        "expect": [
          { "method": "sendMessage" }
        ]
      }
    ]
  },
  {
    "name": "Travel Assistant — escalation creates support ticket",
    "steps": [
      {
        "send": { "callback": "ai:chat" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "ai:escalate" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  }
]
