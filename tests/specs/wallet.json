[
  {
    "name": "/wallet shows empty wallet state",
    "steps": [
      {
        "send": { "text": "/wallet" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "💰 Your wallet\n\nBalance: $0.00\n\nNo transactions yet — buy an eSIM or recharge to get started." }
          }
        ]
      }
    ]
  },
  {
    "name": "wallet:show returns to wallet view",
    "steps": [
      {
        "send": { "text": "/wallet" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "wallet:show" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "💰 Your wallet\n\nBalance: $0.00\n\nNo transactions yet — buy an eSIM or recharge to get started." }
          }
        ]
      }
    ]
  },
  {
    "name": "wallet:coupon shows coupon input prompt",
    "steps": [
      {
        "send": { "text": "/wallet" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "wallet:coupon" },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "Enter your coupon code to redeem it.\n\nJust type or paste the code here." }
          }
        ]
      }
    ]
  },
  {
    "name": "wallet:coupon redemption adds credit to balance",
    "steps": [
      {
        "send": { "text": "/wallet" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "wallet:coupon" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "WELCOME" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Coupon \"WELCOME\" redeemed! $2.00 has been added to your wallet.\n\nNew balance: $2.00" }
          }
        ]
      }
    ]
  },
  {
    "name": "wallet:referral shows referral code",
    "steps": [
      {
        "send": { "text": "/wallet" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "wallet:referral" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  }
]
